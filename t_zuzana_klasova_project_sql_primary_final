-- Vytvoření první tabulky t_zuzana_klasova_project_SQL_primary_final --

CREATE TABLE t_zuzana_klasova_project_SQL_primary_final AS
WITH wages AS (
    ---Čistá data o mzdách---
    SELECT 
        cp.payroll_year AS year,
        cpib.name AS industry_branch,
        cp.value AS avg_wage
    FROM czechia_payroll cp
    JOIN czechia_payroll_industry_branch cpib 
        ON cp.industry_branch_code = cpib.code
        WHERE cp.value_type_code = 5958 --Pouze průměrné hrubé mzdy--
      AND cp.calculation_code = 200 --Přepočtený počet zaměstnanců--
      AND cp.industry_branch_code IS NOT NULL --Zbavíme se NULL hodnot--
),
prices AS (
--Čistá data o cenách--
    SELECT 
        EXTRACT(YEAR FROM cpr.date_from) AS year, 
        cpc.name AS food_category,
        cpr.value AS avg_price,
        cpc.price_value,
        cpc.price_unit
    FROM czechia_price cpr
    JOIN czechia_price_category cpc 
        ON cpr.category_code = cpc.code
    WHERE cpr.region_code IS NULL         
) -- Chceme jen celorepublikový průměr,ne jednotlivé kraje --
-- Propojíme mzdy a ceny přes společný rok --
SELECT 
    w.year,
    w.industry_branch,
    w.avg_wage,
    p.food_category,
    p.avg_price,
    p.price_value,
    p.price_unit
FROM wages w
JOIN prices p 
    ON w.year = p.year;
----------------------------------------------------------------------------------------------
SELECT * 
FROM t_zuzana_klasova_project_SQL_primary_final;

